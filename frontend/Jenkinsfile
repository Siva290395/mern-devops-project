pipeline {
    agent any

    environment {
        FRONTEND_IMAGE = 'frontend-app'
        FRONTEND_CONTAINER = 'frontend-container'
        FRONTEND_PORT = '3000'
        GIT_REPO_URL = 'https://github.com/Siva290395/mern-devops-project.git'
        GIT_BRANCH = 'main'
    }

    stages {
        stage('Checkout Code from SCM') {
            steps {
                git branch: "${GIT_BRANCH}", 
                    url: "${GIT_REPO_URL}",
                    credentialsId: 'github-credentials'
                
                echo "✅ Successfully checked out from ${GIT_REPO_URL}"
                echo "📂 Current directory: ${pwd()}"
            }
        }

        stage('Build Frontend Docker Image') {
            steps {
                dir('frontend') {
                    sh '''
                        echo "🐳 Building frontend Docker image..."
                        docker build -t ${FRONTEND_IMAGE}:latest .
                        echo "✅ Image built successfully: ${FRONTEND_IMAGE}:latest"
                    '''
                }
            }
        }

        stage('Stop and Remove Old Container') {
            steps {
                sh '''
                    echo "🛑 Stopping old container..."
                    docker stop ${FRONTEND_CONTAINER} 2>/dev/null || true
                    docker rm ${FRONTEND_CONTAINER} 2>/dev/null || true
                    echo "✅ Old container removed"
                '''
            }
        }

        stage('Run New Frontend Container') {
            steps {
                sh '''
                    echo "🚀 Starting new frontend container..."
                    docker run -d \
                        --name ${FRONTEND_CONTAINER} \
                        -p ${FRONTEND_PORT}:3000 \
                        --restart unless-stopped \
                        ${FRONTEND_IMAGE}:latest
                    
                    echo "✅ Container started successfully"
                    echo "📍 Frontend running on http://localhost:${FRONTEND_PORT}"
                '''
            }
        }

        stage('Verify Container Status') {
            steps {
                sh '''
                    echo "🔍 Checking container status..."
                    sleep 5
                    
                    echo "📊 Container List:"
                    docker ps --filter "name=${FRONTEND_CONTAINER}"
                    
                    echo "📝 Container Logs:"
                    docker logs ${FRONTEND_CONTAINER} --tail 20
                    
                    echo "🌐 Testing connection..."
                    curl -f http://localhost:${FRONTEND_PORT} || echo "Waiting for app to start..."
                '''
            }
        }
    }

    post {
        success {
            echo '''
                ═══════════════════════════════════════
                ✅ FRONTEND DEPLOYMENT SUCCESSFUL! ✅
                ═══════════════════════════════════════
                📍 Access at: http://localhost:3000
                🐳 Container: frontend-container
                🔄 Status: Running
                ═══════════════════════════════════════
            '''
        }
        failure {
            echo '''
                ═══════════════════════════════════════
                ❌ FRONTEND DEPLOYMENT FAILED! ❌
                ═══════════════════════════════════════
            '''
            sh '''
                echo "🔍 Debug Information:"
                echo "Container logs:"
                docker logs ${FRONTEND_CONTAINER} 2>/dev/null || echo "Container not found"
                echo "Docker images:"
                docker images | grep ${FRONTEND_IMAGE}
            '''
        }
        always {
            echo "🏁 Pipeline execution completed at ${new Date()}"
        }
    }
}
